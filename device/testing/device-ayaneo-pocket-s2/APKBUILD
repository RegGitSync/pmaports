# Reference: <https://postmarketos.org/devicepkg>
maintainer="Neil Armstrong <neil.armstrong@linaro.org>"
pkgname=device-ayaneo-pocket-s2
pkgdesc="Ayaneo Pocket S2"
pkgver=9
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf-ayaneo-pocket-s2
	firmware-ayaneo-pocket-renesas-usb
	firmware-ayaneo-pocket-s2-adreno
	firmware-ayaneo-pocket-s2-adsp
	firmware-ayaneo-pocket-s2-ath12k
	firmware-ayaneo-pocket-s2-cdsp
	firmware-ayaneo-pocket-s2-iris
	firmware-ayaneo-pocket-s2-tplg
	linux-ayaneo-pocket-s2
	linux-firmware-ath12k
	linux-firmware-qca
	linux-firmware-qcom
	postmarketos-base
	soc-qcom
	systemd-boot
	ayaneo-platformd
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	kernel-cmdline.conf
	firmware.files
	modules-initfs
	ayaneo_type9.yaml
	ayaneo_type10.yaml
	50-ayaneo_pocket_s2.yaml
	50-ayaneo.preset
"
subpackages="
	$pkgname-inputplumber:inputplumber:noarch
	$pkgname-steam
	$pkgname-systemd
"

build() {
	devicepkg_build $startdir $pkgname
}

steam() {
	pkgdesc="$pkgname (Steam addons)"
	install_if="postmarketos-ui-steamos"
	depends="decky-ayaneo"

	# Set up CPU affinity for games, we use all except the bottom 2 efficiency cores
	mkdir -p "$subpkgdir"/usr/lib/systemd/user/steam-alongside-.service.d
	cat <<- EOF > "$subpkgdir"/usr/lib/systemd/user/steam-alongside-.service.d/10-cpu.conf
	[Service]
	CPUAffinity=
	CPUAffinity=4,5,6,7
	EOF

	# System services get 2 efficiency cores
	cat <<- EOF > "$subpkgdir"/usr/lib/systemd/system.conf
	[Service]
	CPUAffinity=0,1
	EOF

	# Limit steam to 2 other efficiency cores, these are enough for 60fps UI
	mkdir -p "$subpkgdir"/usr/lib/systemd/user/gamescope-session-plus@steam.service.d
	cat <<- EOF > "$subpkgdir"/usr/lib/systemd/user/gamescope-session-plus@steam.service.d/10-cpu.conf
	[Service]
	CPUAffinity=
	CPUAffinity=2,3
	EOF
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/firmware.files \
		-t "$pkgdir"/usr/share/mkinitfs/files

	install -Dm644 "$srcdir"/50-ayaneo.preset -t "$pkgdir"/usr/lib/systemd/system-preset
}

systemd() {
	default_systemd

	# DrKonqi is full of whimsy and crashloops, causing OOM due to all the
	# coredumps being processed (:
	mkdir -p "$pkgdir"/etc/systemd/user/
	ln -sf /dev/null "$pkgdir"/etc/systemd/user/drkonqi-coredump-launcher.socket
}
inputplumber() {
	pkgdesc="$pkgname (inputplumber configs)"
	depends="inputplumber"
	install_if="$pkgname=$pkgver-r$pkgrel"
	install -Dm644 "$srcdir"/50-ayaneo_pocket_s2.yaml \
		-t "$subpkgdir"/usr/share/inputplumber/devices/
	install -Dm644 "$srcdir"/ayaneo_type9.yaml \
		-t "$subpkgdir"/usr/share/inputplumber/capability_maps/
	install -Dm644 "$srcdir"/ayaneo_type10.yaml \
		-t "$subpkgdir"/usr/share/inputplumber/capability_maps/
}

