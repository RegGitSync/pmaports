# Reference: <https://postmarketos.org/devicepkg>
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=device-fyde-fydetab-duo
pkgdesc="Fyde Fydetab Duo"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
depends="
	firmware-ap6275p
	linux-fydetab-duo
	postmarketos-base
	u-boot-fydetab-duo
"
makedepends="
	devicepkg-dev
"
source="
	deviceinfo
	modules-initfs
	99-debug.conf
"
options="!check !archcheck"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm 644 99-debug.conf "$pkgdir"/etc/kernel-cmdline.d/99-debug.conf
}

