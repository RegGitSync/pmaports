maintainer="Paul Sajna <sajattack@postmarketos.org>"
pkgname=firmware-lg-judyln
pkgver=2
pkgrel=0
pkgdesc="Firmware for LG G7 ThinQ"
url="https://gitlab.com/sajattack/firmware-lg-judyln"
arch="aarch64"
depends="linux-firmware-ath10k"
license="proprietary"
options="!strip !check !archcheck !tracedeps textrels pmb:cross-native"

_commit="acaf7bb99ba2f14318d2fcd08db5f58590b89c75"

source="$pkgname.tar.gz::$url/-/archive/$_commit/$pkgname-$_commit.tar.gz
	firmware.files
	firmware-initramfs.files
	"

package() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		install -Dm644 "$srcdir/$pkgname-$_commit/$_i" "$pkgdir/usr/$_i"
	done < "$srcdir/firmware.files"

	install -Dm644 "$srcdir"/firmware-initramfs.files \
		"$pkgdir"/usr/share/mkinitfs/files/"$pkgname".files
}

