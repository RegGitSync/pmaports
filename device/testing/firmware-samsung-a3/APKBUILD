maintainer="Mis012 <Michael.Srba@seznam.cz>"
pkgname=firmware-samsung-a3
pkgver=2
pkgrel=0
pkgdesc="WiFi/BT firmware for Samsung Galaxy A3 (2015)"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/X3t8q7ue"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
replaces="
	${pkgname}lte-wcnss
	${pkgname}ulte-wcnss
	$pkgname-wcnss-nv
	"
builddir="$srcdir"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$srcdir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima
}

