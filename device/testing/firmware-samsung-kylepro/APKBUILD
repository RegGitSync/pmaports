	# Bluetooth
	install -Dm644 proprietary/bin/BCM4330B1_002.001.003.0967.1173.hcd \
		"$pkgdir"/lib/firmware/postmarketos/brcm/BCM4330B1.samsung,kylepro.hcd
}
