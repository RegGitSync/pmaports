# Maintainer: alghiffaryfa19 <alghiffaryfa19@gmail.com>
pkgname=firmware-xiaomi-sheng
pkgver=20240917
pkgrel=1
pkgdesc="Firmware for Xiaomi Mi Pad 6s Pro"
url="https://github.com/alghiffaryfa19/sheng-firmware"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
_commit="de3c36fc1564ce383294e470d3c00185a3f7f39b"
source="
	$pkgname-$_commit.tar.gz::https://github.com/alghiffaryfa19/sheng-firmware/archive/$_commit.tar.gz
	30-gpu-firmware.files
"
depends="
	linux-firmware-ath12k
	linux-firmware-qcom
	linux-firmware-qca
	"
builddir="$srcdir/sheng-firmware-$_commit"

package() {
	install -d "$pkgdir/lib/firmware"

	cd "$builddir"

	find . -type d -exec install -d "$pkgdir/lib/firmware/{}" \;

	find . -type f -exec install -Dm644 "{}" "$pkgdir/lib/firmware/{}" \;

	install -Dm644 "$srcdir/30-gpu-firmware.files" -t \
		"$pkgdir"/usr/share/mkinitfs/files
}
