maintainer="Kevin Widjaja <kevinwidjaja_dev@proton.me>"
pkgname=linux-anbernic-rgxxxx
pkgver=7.1.3
pkgrel=0
pkgdesc="Close-to-mainline kernel fork for Anbernic RGXXXX H700 devices"
arch="aarch64"
_carch="arm64"
_flavor="anbernic-rgxxxx"
url="https://kernel.org"
license="GPL-2.0-only"
makedepends="
	bison
	clang
	elfutils-dev
	findutils
	flex
	linux-headers
	lld
	llvm
	openssl-dev
	pahole
	perl
	postmarketos-installkernel
	python3
	zstd
	"
options="!strip !check !tracedeps
	pmb:cross-native
	pmb:kconfigcheck-community
	"

# Source
_repository="linux"
_patches_repo="minime"
_pkgver="7.1.3"
_commit="90be143be6834e5b5fb93c3f734c98259f7f3b9c"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_pkgver.tar.gz::https://www.kernel.org/pub/${_repository}/kernel/v${_pkgver/.*/}.x/linux-${_pkgver}.tar.gz
	$_patches_repo-$_commit.tar.gz::https://github.com/minime-os/$_patches_repo/archive/$_commit.tar.gz
	patch.files
	01-remove-rocknix-dt-id.patch
	02-v2_20250226_kikuchan98_drm_panel_add_generic_mipi_panel_driver.patch
	$_config
"
builddir="$srcdir/$_repository-$_pkgver"

prepare() {
	
	# Apply select patches to the mainline kernel.
	while IFS="" read -r _i || [ -n "$_i" ]; do
		patch -p1 < "$srcdir/$_patches_repo-$_commit/$_i"
	done < "$srcdir/patch.files"

	makefile="$builddir/arch/arm64/boot/dts/allwinner/Makefile"

	for dts in "$srcdir/$_patches_repo"-*/external/board/h700/dts/*dts*; do
		dtb="$(basename "$dts" | sed 's/\.dts$/.dtb/')"

		# Move the devicetree sources in the kernel tree.
		cp "$dts" "arch/arm64/boot/dts/allwinner/"

		# Mention the devicetree blobs in the Makefile for
		# compilation if they're absent.
		if ! grep -q "$dtb" "$makefile"; then
			echo "dtb-\$(CONFIG_ARCH_SUNXI) += $dtb" >> "$makefile"
		fi
	done

	default_prepare
	cp "$srcdir"/config-$_flavor.$arch .config
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	make LLVM=1 zinstall modules_install dtbs_install \
		ARCH="$_carch" \
		LLVM=1 \
		INSTALL_PATH="$pkgdir/boot" \
		INSTALL_MOD_STRIP=1 \
		INSTALL_MOD_PATH="$pkgdir"/usr \
		INSTALL_DTBS_PATH="$pkgdir/boot/dtbs"

	install -D "$builddir"/include/config/kernel.release \
		"$pkgdir"/usr/share/kernel/$_flavor/kernel.release
}

