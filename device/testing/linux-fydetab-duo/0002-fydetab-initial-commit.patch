diff --git a/drivers/net/wireless/broadcom/brcm80211/brcmfmac/pcie.c b/drivers/net/wireless/broadcom/brcm80211/brcmfmac/pcie.c
index 45b342ea0637..414742c82650 100644
--- a/drivers/net/wireless/broadcom/brcm80211/brcmfmac/pcie.c
+++ b/drivers/net/wireless/broadcom/brcm80211/brcmfmac/pcie.c
@@ -2153,6 +2153,15 @@ static void brcmf_pcie_setup(struct device *dev, int ret,
 
 	brcmf_pcie_attach(devinfo);
 
+	/* Reset the device before downloading firmware. Otherwise loading
+	 * firmware fail around half of the time (both on cold and warm boots).
+	 * PCIe PERST alone is not enough on the BCM43752/AP6275P on the Fyde
+	 * Fydetab Duo.
+	 *
+	 * I have no idea if this is suitable for upstream, but it works.
+	 */
+	brcmf_pcie_reset_device(devinfo);
+
 	fw = fwreq->items[BRCMF_PCIE_FW_CODE].binary;
 	nvram = fwreq->items[BRCMF_PCIE_FW_NVRAM].nv_data.data;
 	nvram_len = fwreq->items[BRCMF_PCIE_FW_NVRAM].nv_data.len;
