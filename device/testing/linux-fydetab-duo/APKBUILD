# Reference: <https://postmarketos.org/vendorkernel>
# Kernel config from: https://github.com/Linux-for-Fydetab-Duo/linux-rockchip branch noble-panthor
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=linux-fydetab-duo
pkgver=7.1.2
_kernver=${pkgver%.*}
pkgrel=0
pkgdesc="Linux kernel for Fydetab Duo"
arch="aarch64"
_carch="arm64"
_flavor="fydetab-duo"
url="https://kernel.org"
license="GPL-2.0-only"
# TODO: stale makedepends?
makedepends="
	bash
	bison
	clang
	devicepkg-dev
	dtc
	findutils
	flex
	linux-firmware
	linux-headers
	lld
	llvm
	openssl-dev
	pahole
	perl
	python3
	xz
	zstd
"
checkdepends="
	py3-dt-schema
	flex
	bison
	yamllint
	"
_config="config-$_flavor.$arch"
# get patch releases
if [ "${pkgver/*./}" -ne 0 ]; then
	source="$pkgname-$pkgver.patch.xz::https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/patch-$pkgver.xz"
fi
source="
	$source
	https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/linux-$_kernver.tar.xz
	0001-dt-bindings-bluetooth-broadcom-add-BCM43752.patch
	0002-fydetab-initial-commit.patch
	0003-wip.patch
	$_config
"
options="!strip !check !tracedeps pmb:cross-native"
builddir="$srcdir"/linux-$_kernver

prepare() {
	default_prepare
	cp "$srcdir/config-$_flavor.$arch" .config
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-$_flavor" \
		Image modules dtbs
}

check() {
	#TODO: remove options=!check
	make ARCH=arm64 LLVM=1 dt_binding_check DT_SCHEMA_FILES=rockchip
	make ARCH=arm64 LLVM=1 CHECK_DTBS=y rockchip/rk3588s-fydetab-duo.dtb
}

package() {
	install -Dm644 "$builddir/$_outdir/arch/$_carch/boot/Image" \
		"$pkgdir/boot/vmlinuz"

	make modules_install dtbs_install \
		ARCH="$_carch" \
		LLVM=1 \
		INSTALL_PATH="$pkgdir"/boot/ \
		INSTALL_MOD_PATH="$pkgdir"/usr \
		INSTALL_MOD_STRIP=1 \
		INSTALL_DTBS_PATH="$pkgdir"/boot/dtbs
	rm -f "$pkgdir"/lib/modules/*/build "$pkgdir"/lib/modules/*/source

	install -D "$builddir"/include/config/kernel.release \
		"$pkgdir"/usr/share/kernel/$_flavor/kernel.release
}

