# Reference: <https://postmarketos.org/mainline>
# Kernel config based on: arch/arm/configs/multi_v7_defconfig
maintainer="knuxify <knuxify@gmail.com>"
pkgname=linux-postmarketos-brcm-kona
pkgver=7.1_git20260708
pkgrel=0
pkgdesc="Mainline kernel fork for Broadcom Kona devices"
arch="armv7"
_carch="arm"
_flavor="${pkgname#linux-}"
url="https://github.com/bcm-kona-mainline/linux"
license="GPL-2.0-only"
options="!strip !check !tracedeps
	pmb:cross-native
	pmb:kconfigcheck-community
	"
makedepends="
	bash
	bc
	bison
	clang
	elfutils-dev
	findutils
	flex
	lld
	llvm
	linux-headers
	openssl-dev
	pahole
	perl
	postmarketos-installkernel
	python3
	xz
	zstd
	"
_commit="3408464721788020a3fa9c2e87e4d3228d4a8c59"
_defconfig="defconfig"
_config="
	config-$_flavor.$arch
	kona.config
	misc.config
	pmos.config
"
source="
	$pkgname-$_commit.tar.gz::https://github.com/bcm-kona-mainline/linux/archive/$_commit/linux-$_commit.tar.gz
	$_config
"
builddir="$srcdir/linux-$_commit"

prepare() {
	default_prepare
	cp -v "$srcdir"/config-$_flavor.$arch .config
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	mkdir -p "$pkgdir"/boot
	make zinstall modules_install dtbs_install \
		ARCH="$_carch" \
		LLVM=1 \
		INSTALL_MOD_STRIP=1 \
		INSTALL_PATH="$pkgdir"/boot \
		INSTALL_MOD_PATH="$pkgdir"/usr \
		INSTALL_DTBS_PATH="$pkgdir/boot/dtbs"

	install -D "$builddir"/include/config/kernel.release \
				"$pkgdir/usr/share/kernel/$_flavor/kernel.release"
}

