CONFIG_ARCH_BCM=y
# CONFIG_ARCH_BCM_IPROC is not set
# CONFIG_ARCH_BCM_CYGNUS is not set
# CONFIG_ARCH_BCM_HR2 is not set
# CONFIG_ARCH_BCM_NSP is not set
# CONFIG_ARCH_BCM_5301X is not set
# CONFIG_ARCH_BCM2835 is not set
# CONFIG_ARCH_BCM_53573 is not set
# CONFIG_ARCH_BRCMSTB is not set
# CONFIG_ARCH_BCMBCA is not set
CONFIG_ARCH_BCM_MOBILE=y
CONFIG_ARCH_BCM_281XX=y
CONFIG_ARCH_BCM_21664=y
CONFIG_ARCH_BCM_23550=y
CONFIG_ARCH_BCM_MOBILE_L2_CACHE=y
CONFIG_ARCH_BCM_MOBILE_SMC=y
CONFIG_ARCH_BCM_MOBILE_SMP=y
CONFIG_I2C_BCM_KONA=y
CONFIG_PINCTRL_BCM281XX=y
CONFIG_GPIO_BCM_KONA=y
CONFIG_BCM_KONA_WDT=y
CONFIG_MMC_SDHCI_BCM_KONA=y
CONFIG_CLK_BCM_KONA=y
CONFIG_BCM_KONA_TIMER=y
CONFIG_PWM_BCM_KONA=y
CONFIG_BCM_KONA_USB2_PHY=y
CONFIG_POWER_RESET_BRCMKONA=y

# BCM590xx MFD
CONFIG_MFD_BCM590XX=y
CONFIG_REGULATOR_BCM590XX=y
CONFIG_RTC_DRV_BCM590XX=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_BCM590XX_PONKEY=y
CONFIG_POWER_RESET_BCM590XX=y

# DRM_SIMPLEDRM for simple-framebuffer
# (VC4/proper GPU is not supported for Kona yet)
CONFIG_DRM_SIMPLEDRM=y

# Needed by devices
CONFIG_I2C_GPIO=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_REGULATOR=y
CONFIG_BRCMUTIL=m
CONFIG_BRCMFMAC=m
CONFIG_BRCMFMAC_SDIO=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_MMS114=y
CONFIG_BMC150_ACCEL=m
CONFIG_BMC150_ACCEL_I2C=m
CONFIG_GP2AP002=m
CONFIG_AK8974=m
CONFIG_BACKLIGHT_KTD253=m
CONFIG_EXTCON_FSA9480=y
CONFIG_EXTCON_RT8973A=y
