CONFIG_NO_HZ=y

# Use XZ for kernel compression
# CONFIG_KERNEL_GZIP is not set
CONFIG_KERNEL_XZ=y

# Use GZIP or ZSTD for ramdisk compression
CONFIG_RD_GZIP=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
CONFIG_RD_ZSTD=y

# Add splash parameter for boot splash
# (stock bootloaders ignore cmdline from boot.img and other sources)
CONFIG_ATAGS=y
CONFIG_ARM_ATAG_DTB_COMPAT=y
# CONFIG_ARM_ATAG_DTB_COMPAT_CMDLINE_FROM_BOOTLOADER is not set
CONFIG_ARM_ATAG_DTB_COMPAT_CMDLINE_EXTEND=y
CONFIG_CMDLINE="splash"
# CONFIG_CMDLINE_FROM_BOOTLOADER is not set
CONFIG_CMDLINE_EXTEND=y
# CONFIG_CMDLINE_FORCE is not set

# Enable appended DTB support
CONFIG_ARM_APPENDED_DTB=y

# Make some things modules
CONFIG_HID=m
CONFIG_MOUSE_PS2=m
CONFIG_SERIO=m
CONFIG_HWMON=m
CONFIG_NTFS_FS=m

