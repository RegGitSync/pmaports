# Reference: <https://postmarketos.org/devicepkg>
# Contributor: Seshan Ravikumar <seshan@sineware.ca>
maintainer="Kevin Widjaja <kevinwidjaja_dev@proton.me>"
pkgname=mapper-anbernic-rgxxxx
pkgdesc="Anbernic H700 D-pad to mouse mapper"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="py3-evdev"
subpackages="
	$pkgname-systemd
	$pkgname-openrc
"
source="
	rgxxxx-control-mapper.py
	rgxxxx-control-mapper.service
	rgxxxx-control-mapper.initd
"

package() {
	install -Dm755 "$srcdir"/rgxxxx-control-mapper.py \
		"$pkgdir"/usr/bin/rgxxxx-control-mapper
}

systemd() {
	install_if="$pkgname=$pkgver-r$pkgrel systemd"
	install -Dm644 "$srcdir"/rgxxxx-control-mapper.service \
		"$subpkgdir"/usr/lib/systemd/system/rgxxxx-control-mapper.service
	mkdir -p "$subpkgdir"/usr/lib/systemd/system/multi-user.target.wants/
	ln -sf /usr/lib/systemd/system/rgxxxx-control-mapper.service \
		"$subpkgdir"/usr/lib/systemd/system/multi-user.target.wants/rgxxxx-control-mapper.service
	default_systemd
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	install="$subpkgname.post-install"
	install -Dm755 "$srcdir"/rgxxxx-control-mapper.initd \
		"$subpkgdir"/etc/init.d/rgxxxx-control-mapper
	default_openrc
}

