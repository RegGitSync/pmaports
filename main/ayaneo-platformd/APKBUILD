maintainer="Victoria Brekenfeld <pkg@drakulix.de>"
pkgname=ayaneo-platformd
pkgver=1.0.6
pkgrel=0
pkgdesc="Ayaneo platform daemon"
url="https://gitlab.postmarketos.org/condenser/ayaneo-platformd"
arch="all"
depends="
	elogind
	upower
"
makedepends="
	sccache
	rust
	cargo
"
license="GPL-3"
options="!check !pmb:crossdirect"

source="https://gitlab.postmarketos.org/condenser/ayaneo-platformd/-/archive/v$pkgver/ayaneo-platformd-v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"

subpackages="
	$pkgname-systemd:systemd:noarch
"

prepare() {
	default_prepare
	cargo fetch --locked
}

build() {
	make build
}

package() {
	make install PREFIX="$pkgdir"/usr
}

systemd() {
	default_systemd
}

