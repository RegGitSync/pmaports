From 4090316fede1b0dfa0173b063f86346fca3d3f0d Mon Sep 17 00:00:00 2001
From: Victoria Brekenfeld <github@drakulix.de>
Date: Sun, 5 Jul 2026 11:46:40 +0200
Subject: [PATCH 1/3] build: use system dependencies

---
 backend/pyproject.toml | 9 ++++-----
 1 file changed, 4 insertions(+), 5 deletions(-)

diff --git a/backend/pyproject.toml b/backend/pyproject.toml
index 2793439..3e91af3 100644
--- a/backend/pyproject.toml
+++ b/backend/pyproject.toml
@@ -1,6 +1,6 @@
 [tool.poetry]
 name = "decky-loader"
-version = "0.0.0"  # the real version will be autogenerated
+version = "3.2.6"
 description = "A plugin loader for the Steam Deck"
 license = "GPLv2"
 authors = []
@@ -14,7 +14,7 @@ include = [
 ]
 
 [tool.poetry.dependencies]
-python = ">=3.10,<3.14"
+python = ">=3.10"
 
 aiohttp = "^3.10.11"
 aiohttp-jinja2 = "^1.5.1"
@@ -26,7 +26,6 @@ multidict = "^6.0.5"
 setproctitle = "^1.3.3"
 
 [tool.poetry.group.dev.dependencies]
-pyinstaller = "^6.8.0"
 pyright = "^1.1.335"
 
 [tool.poetry.scripts]
@@ -43,5 +42,5 @@ enable = true
 files = []
 
 [build-system]
-requires = ["poetry-core>=1.0.0", "poetry-dynamic-versioning>=1.0.0,<2.0.0"]
-build-backend = "poetry_dynamic_versioning.backend"
+requires = ["poetry-core>=1.0.0"]
+build-backend = "poetry.core.masonry.api"
-- 
