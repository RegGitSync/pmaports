maintainer="Victoria Brekenfeld <pkg@drakulix.de>"
pkgname=decky-loader
pkgver=3.2.6
pkgrel=0
pkgdesc="A plugin loader for the Steam Deck"
url="https://github.com/SteamDeckHomebrew/decky-loader"
arch="all"
depends="
	py3-aiohttp
	py3-aiohttp-jinja2
	py3-aiohttp-cors
	py3-watchdog
	py3-certifi
	py3-packaging
	py3-multidict
	py3-setproctitle
"
makedepends="
	nodejs
	pnpm
	python3-dev
	py3-poetry-core
	py3-gpep517
"
license="GPL-2"
options="!check"

source="
	$pkgname-v$pkgver.tar.gz::https://github.com/SteamDeckHomebrew/decky-loader/archive/refs/tags/v$pkgver.tar.gz
	decky-loader.service
	0001-build-use-system-dependencies.patch
	0002-frontend-Hide-updater.patch
	0003-frontend-Add-pmos-warning.patch
	91-decky-loader.preset
"

subpackages="
	$pkgname-systemd
	$pkgname-pyc
"

prepare() {
	default_prepare

	cd "$builddir"/frontend
	pnpm i --frozen-lockfile --dangerously-allow-all-builds
}

build() {
	cd "$builddir"/frontend
	pnpm run build

	cd "$builddir"/backend
	export POETRY_DYNAMIC_VERSIONING_BYPASS="$pkgver"
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

package() {
	python3 -m installer -d "$pkgdir" "$builddir"/backend/.dist/*.whl
	install -Dm644 "$srcdir"/decky-loader.service "$pkgdir"/usr/lib/systemd/user/decky-loader.service
	install -Dm644 "$srcdir"/91-decky-loader.preset -t "$pkgdir"/usr/lib/systemd/user-preset/
}

