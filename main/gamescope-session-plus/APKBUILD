maintainer="Victoria Brekenfeld <pkg@drakulix.de>"
pkgname=gamescope-session-plus
pkgver=0.0.0
pkgrel=1
pkgdesc="Gamescope session plus based on Valve's gamescope"
url="https://github.com/ChimeraOS/gamescope-session"
arch="noarch"
license="MIT"
depends="
	bash
	systemd
	dbus
	gamescope
"
options="!check" # no tests
subpackages="$pkgname-systemd"
_commit=73d2da84ace7f41006a0f85bd2fdb19ef593a464
source="
	gamescope-session-$_commit.zip::https://github.com/ChimeraOS/gamescope-session/archive/$_commit.zip
	0001-add-pocket-s2.patch
	0002-fix-shell.patch
"
builddir="$srcdir/gamescope-session-$_commit"

package() {
	install -Dm755 "$builddir"/usr/bin/gamescope-session-plus -t "$pkgdir"/usr/bin/
	install -Dm755 "$builddir"/usr/bin/export-gpu -t "$pkgdir"/usr/bin/
	install -Dm644 "$builddir"/usr/lib/systemd/user/gamescope-session-plus@.service -t "$pkgdir"/usr/lib/systemd/user/
	install -Dm644 "$builddir"/usr/share/gamescope-session-plus/device-quirks -t "$pkgdir"/usr/share/gamescope-session-plus/
	install -Dm755 "$builddir"/usr/share/gamescope-session-plus/gamescope-session-plus -t "$pkgdir"/usr/share/gamescope-session-plus/
	install -Dm644 "$builddir"/usr/share/gamescope/scripts/50-custom/50-disable-explicit-sync.lua -t "$pkgdir"/usr/share/gamescope/scripts/50-custom/
}

systemd() {
	default_systemd
}

