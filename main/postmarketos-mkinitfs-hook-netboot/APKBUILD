maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=postmarketos-mkinitfs-hook-netboot
pkgver=4.3.0
pkgrel=1
pkgdesc="Netboot postmarketOS using nbd feature (only works with systemd)"
url="https://postmarketos.org"
depends="devicepkg-utils postmarketos-mkinitfs"
source="
	disable-usb-moded.preset
	netboot.sh
	netboot.modules
	"
arch="noarch"
license="GPL-2.0-or-later"
subpackages="$pkgname-systemd"
options="!check" # No tests

package() {
	install -Dm644 "$srcdir"/netboot.sh \
		"$pkgdir"/usr/share/mkinitfs/hooks/netboot.sh
	install -Dm644 "$srcdir"/netboot.modules \
		"$pkgdir"/usr/share/mkinitfs/modules/30-netboot.modules
	install -Dm644 "$srcdir"/disable-usb-moded.preset \
		"$pkgdir"/usr/lib/systemd/system-preset/70-"$pkgname".preset
}

