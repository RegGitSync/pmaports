# Reference: https://postmarketos.org/uipkg
maintainer="Victoria Brekenfeld <pkg@drakulix.de>"
pkgname=postmarketos-ui-steamos
pkgver=1
pkgrel=0
pkgdesc="SteamOS like gamescope session"
arch="noarch"
license="GPL-3.0-or-later"
url="https://postmarketos.org"
depends="
	postmarketos-ui-plasma-desktop
	postmarketos-ui-plasma-desktop-systemd
	postmarketos-base-ui-audio-backend-pipewire
	postmarketos-base-ui-networkmanager
	gamescope-session-steam
	steamos-manager
	steamos-powerbuttond
	steam-notif-daemon
	"
_pmb_recommends="
	decky-loader
	"

source="
	firstboot-autologin.service
	firstboot-autologin.conf
	91-postmarketos-ui-steamos.preset
	gaming-return.svg
	Return.desktop
	Steam.desktop
	"
subpackages="$pkgname-systemd"
options="!check pmb:systemd" # No tests for a metapkg

package() {
	install -Dm644 firstboot-autologin.service -t "$pkgdir"/usr/lib/systemd/system/
	install -Dm644 firstboot-autologin.conf -t "$pkgdir"/usr/lib/tmpfiles.d/
	install -Dm644 91-postmarketos-ui-steamos.preset -t "$pkgdir"/usr/lib/systemd/system-preset/
	install -Dm644 gaming-return.svg -t "$pkgdir"/usr/share/icons/hicolor/scalable/actions/
	install -Dm644 Return.desktop -t "$pkgdir"/etc/skel/Desktop/
	install -Dm644 Steam.desktop -t "$pkgdir"/etc/skel/Desktop/
	install -Dm644 Steam.desktop -t "$pkgdir"/etc/skel/.local/share/applications/
}

