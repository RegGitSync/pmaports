maintainer="Victoria Brekenfeld <github@drakulix.de>"
pkgname=steam-notif-daemon
pkgver=1.0.1
pkgrel=0
pkgdesc="Steam notification daemon"
url="https://github.com/evlaV/steam_notif_daemon"
arch="all"
license="MIT"
makedepends="meson systemd-dev curl-dev"
source="
	$pkgname-$pkgver.zip::https://github.com/evlaV/steam_notif_daemon/archive/refs/tags/v$pkgver.zip
	0001-use-steam-from-PATH.patch
"
options="!check" # no tests
builddir="$srcdir/steam_notif_daemon-$pkgver"

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

