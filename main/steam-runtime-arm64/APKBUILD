maintainer="Victoria Brekenfeld <pkg@drakulix.de>"
pkgname=steam-runtime-arm64
pkgver=2026.07.14
pkgrel=0
pkgdesc="Valve's Steam digital software delivery system"
url="https://store.steampowered.com"
arch="aarch64"
provides="steam-runtime=$pkgver-r$pkgrel"
depends="
	bubblewrap
	steam-devices
"
makedepends="xz gzip"
license="MIT"
options="!check textrels !strip !archcheck !tracedeps !dbg pmb:cross-native"

_tag=$pkgver
_job=1621592
_steamver=4.0.20260608.242786
source="
	com.valvesoftware.SteamRuntime.Platform-arm64-steamrt4-sysroot.tar.gz::https://repo.steampowered.com/steamrt4/images/$_steamver/com.valvesoftware.SteamRuntime.Platform-arm64-steamrt4-sysroot.tar.gz
	com.valvesoftware.SteamRuntime.Platform-amd64-i386-steamrt4-sysroot.tar.gz::https://repo.steampowered.com/steamrt4/images/$_steamver/com.valvesoftware.SteamRuntime.Platform-amd64,i386-steamrt4-sysroot.tar.gz
	steam-runtime-$_tag.tar.gz::https://gitlab.postmarketos.org/condenser/steam-fex-runtime/-/archive/$_tag/steam-fex-runtime-$_tag.tar.gz
	runtime-arm64-$_job.tar.xz::https://gitlab.postmarketos.org/condenser/steam-fex-runtime/-/jobs/$_job/artifacts/raw/runtime-arm64.tar.xz
	runtime-x86-64-$_job.tar.xz::https://gitlab.postmarketos.org/condenser/steam-fex-runtime/-/jobs/$_job/artifacts/raw/runtime-x86-64.tar.xz
	fex-x86-64-$_job.tar.xz::https://gitlab.postmarketos.org/condenser/steam-fex-runtime/-/jobs/$_job/artifacts/raw/fex-x86-64.tar.xz
	steam_subscriber_agreement.txt.gz
	steam.desktop
	16x16.png
	24x24.png
	32x32.png
	48x48.png
	256x256.png
"
subpackages="
	$pkgname-doc
	$pkgname-systemd
"
builddir="$srcdir/steam-runtime-$_tag/"

unpack() {
	cd "$srcdir"
	tar xf steam-runtime-$_tag.tar.gz
}

package() {
	# data
	install -Dm755 "$srcdir"/steam-fex-runtime-"$_tag"/mkosi.images/base/arm64/data/steam "$pkgdir"/usr/bin/steam
	install -Dm755 "$srcdir"/steam-fex-runtime-"$_tag"/mkosi.images/base/arm64/data/steam-alongside-amd64 "$pkgdir"/usr/libexec/steam-alongside-amd64
	install -Dm644 "$srcdir"/steam-fex-runtime-"$_tag"/mkosi.images/base/arm64/data/steam-alongside-amd64.service "$pkgdir"/usr/lib/systemd/user/steam-alongside-amd64.service
	install -Dm755 "$srcdir"/steam-fex-runtime-"$_tag"/mkosi.images/base/arm64/data/steam-alongside-arm64 "$pkgdir"/usr/libexec/steam-alongside-arm64
	install -Dm644 "$srcdir"/steam-fex-runtime-"$_tag"/mkosi.images/base/arm64/data/steam-alongside-arm64.service "$pkgdir"/usr/lib/systemd/user/steam-alongside-arm64.service

	# runtime
	mkdir -p "$pkgdir"/usr/share/steam-runtime/rt-arm64
	mkdir -p "$pkgdir"/usr/share/steam-runtime/rt-amd64
	mkdir -p "$pkgdir"/usr/share/steam-runtime/pmos-arm64
	mkdir -p "$pkgdir"/usr/share/steam-runtime/pmos-amd64
	mkdir -p "$pkgdir"/usr/share/steam-runtime/fex-amd64
	tar xf "$srcdir"/com.valvesoftware.SteamRuntime.Platform-arm64-steamrt4-sysroot.tar.gz -C "$pkgdir"/usr/share/steam-runtime/rt-arm64
	tar xf "$srcdir"/com.valvesoftware.SteamRuntime.Platform-amd64-i386-steamrt4-sysroot.tar.gz -C "$pkgdir"/usr/share/steam-runtime/rt-amd64
	find "$pkgdir"/usr/share/steam-runtime/rt-arm64 -perm /6000 -exec chmod -s {} \;
	find "$pkgdir"/usr/share/steam-runtime/rt-amd64 -perm /6000 -exec chmod -s {} \;
	tar xf "$srcdir"/runtime-arm64-$_job.tar.xz -C "$pkgdir"/usr/share/steam-runtime/pmos-arm64
	tar xf "$srcdir"/runtime-x86-64-$_job.tar.xz -C "$pkgdir"/usr/share/steam-runtime/pmos-amd64
	tar xf "$srcdir"/fex-x86-64-$_job.tar.xz -C "$pkgdir"/usr/share/steam-runtime/fex-amd64

	# supporting
	install -Dm644 "$srcdir"/steam.desktop "$pkgdir"/usr/share/applications/steam.desktop
	install -Dm644 "$srcdir"/steam_subscriber_agreement.txt.gz "$pkgdir"/usr/share/doc/steam/steam_subscriber_agreement.txt.gz
	install -Dm644 "$srcdir"/16x16.png "$pkgdir"/usr/share/icons/hicolor/16x16/apps/steam.png
	install -Dm644 "$srcdir"/24x24.png "$pkgdir"/usr/share/icons/hicolor/24x24/apps/steam.png
	install -Dm644 "$srcdir"/32x32.png "$pkgdir"/usr/share/icons/hicolor/32x32/apps/steam.png
	install -Dm644 "$srcdir"/48x48.png "$pkgdir"/usr/share/icons/hicolor/48x48/apps/steam.png
	install -Dm644 "$srcdir"/256x256.png "$pkgdir"/usr/share/icons/hicolor/256x256/apps/steam.png
}

doc() {
	provides="steam-runtime-doc=$pkgver-r$pkgrel"
	default_doc
}

