
maintainer="Victoria Brekenfeld <pkg@drakulix.de>"
pkgname=steamos-manager
pkgver=26.0.0
pkgrel=1
pkgdesc="SteamOS Manager is a system daemon that aims to abstract Steam's interactions with the operating system."
url="https://gitlab.steamos.cloud/holo/steamos-manager"
arch="all"
license="MIT"
options="!check !pmb:crossdirect"
depends="orca"
makedepends="
	sccache
	cargo
	rust
	clang21-dev
	eudev-dev
	glib-dev
	speech-dispatcher-dev
	"
depends="pipewire-tools"
source="
	https://gitlab.steamos.cloud/holo/steamos-manager/-/archive/v$pkgver/steamos-manager-v$pkgver.tar.gz
	0001-use-gamescope-session-plus.patch
	0002-use-plasmalogin.patch
	91-steamos-manager.preset
	"
builddir="$srcdir/$pkgname-v$pkgver"

subpackages="
	$pkgname-systemd
	$pkgname-dbus:dbus:noarch
"

build() {
	make
}

package() {
	make install DESTDIR="$pkgdir"
	# conflicts with alpines orca package
	rm $pkgdir/usr/lib/systemd/user/orca.service

	install -Dm644 "$srcdir"/91-steamos-manager.preset -t "$pkgdir"/usr/lib/systemd/system-preset/
	install -Dm644 "$srcdir"/91-steamos-manager.preset -t "$pkgdir"/usr/lib/systemd/user-preset/
}

dbus() {
	pkgdesc="DBus configs for $pkgname"
	install_if="$pkgname=$pkgver-r$pkgrel dbus"
	amove usr/share/dbus-1
}

