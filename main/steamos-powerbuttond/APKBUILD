	https://gitlab.steamos.cloud/holo/powerbuttond/-/archive/$_commit/powerbuttond-$_commit.tar.gz
	0001-run-steam-from-PATH.patch
	0002-Skip-processing-events-during-resume.patch
	0003-bind-to-gamescope-session-plus.patch
"
options="!check" # no tests
builddir="$srcdir/powerbuttond-$_commit"

subpackages="
	$pkgname-udev
	$pkgname-systemd
"

build() {
	LDFLAGS="-lc /usr/lib/crt1.o --dynamic-linker=/lib/ld-musl-aarch64.so.1" make
}

package() {
	make install DESTDIR="$pkgdir"
}

systemd() {
	default_systemd

	rm "$subpkgdir/usr/lib/systemd/user/gamescope-session.service.wants/steamos-powerbuttond.service"
	rmdir "$subpkgdir/usr/lib/systemd/user/gamescope-session.service.wants"
}

