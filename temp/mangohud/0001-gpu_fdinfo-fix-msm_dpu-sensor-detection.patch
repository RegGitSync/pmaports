From: Victoria Brekenfeld <github@drakulix.de>
Date: Fri, 12 Jun 2026 00:19:48 +0200
Subject: [PATCH 1/3] gpu_fdinfo: fix msm_dpu sensor detection

---
 src/gpu_fdinfo.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/gpu_fdinfo.cpp b/src/gpu_fdinfo.cpp
index 0fdd99e..229cd9b 100644
--- a/src/gpu_fdinfo.cpp
+++ b/src/gpu_fdinfo.cpp
@@ -175,7 +175,7 @@ void GPU_fdinfo::find_hwmon_sensors()
 {
     std::string hwmon;
 
-    if (module == "msm")
+    if (module == "msm_dpu")
         hwmon = find_hwmon_sensor_dir("gpu");
     else if (module == "panfrost" || module == "panthor")
         hwmon = find_hwmon_sensor_dir("gpu_thermal");
