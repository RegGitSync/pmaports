maintainer="Clayton Craft <clayton@craftyguy.net>"
pkgname=routewrangler
pkgver=0.1
pkgrel=0
_commit="a49e3b4424b9d4ac50707585f073dc052763eb7b"
pkgdesc="Routing policy daemon for enforcing strict connection preferences in NetworkManager"
url="https://gitlab.postmarketos.org/postmarketOS/routewrangler"
arch="all"
license="GPL-3.0-or-later"
depends="networkmanager"
makedepends="cargo-auditable dbus-dev"
source="https://gitlab.postmarketos.org/postmarketOS/routewrangler/-/archive/$_commit/routewrangler-$_commit.tar.gz"
subpackages="$pkgname-systemd"
options="net"
builddir="$srcdir/$pkgname-$_commit"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen --all
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/routewrangler \
		-t "$pkgdir"/usr/bin
	install -Dm644 data/routewrangler.service \
		-t "$pkgdir"/usr/lib/systemd/system
}

sha512sums="
