maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=seedfiles
pkgver=1.5
pkgrel=0
pkgdesc="Portable drop-in reimplementation of systemd-tmpfiles"
url="https://git.pinkro.se/Rose/gardenhouse/seedfiles.git/about/"
arch="all"
license="GPL-3.0-or-later"
makedepends="acl-dev linux-headers meson"
subpackages="$pkgname-doc $pkgname-openrc"
# Use official mirror because git repo returns 403
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/Gardenhouse/seedfiles/archive/v$pkgver.tar.gz
	0001-test-use-sh-instead-of-bash.patch
	seedfiles-clean.initd
	seedfiles-setup-dev.initd
	seedfiles-setup.initd
	"
builddir="$srcdir/$pkgname"
# check: https://codeberg.org/Gardenhouse/seedfiles/issues/19
options="!check"

build() {
	abuild-meson \
		-Ddefault_configs=disabled \
		. output
	meson compile ${JOBS:+-j ${JOBS}} -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output

	install -Dm755 "$srcdir"/seedfiles-clean.initd \
		"$pkgdir"/etc/init.d/seedfiles-clean
	install -Dm755 "$srcdir"/seedfiles-setup-dev.initd \
		"$pkgdir"/etc/init.d/seedfiles-setup-dev
	install -Dm755 "$srcdir"/seedfiles-setup.initd \
		"$pkgdir"/etc/init.d/seedfiles-setup
}

